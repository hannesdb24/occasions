// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  image        String?
  state        String?  // Bundesland-Code z.B. "BY", "BE"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts         Contact[]         @relation("ContactOwner")
  linkedContacts   Contact[]         @relation("LinkedContact")
  wishList         WishList?
  invitesSent      Invitation[]      @relation("InvitedBy")
  invitedVia       Invitation?       @relation("InvitedUser")
  reminderSettings ReminderSetting[]
  reservations     WishItem[]        @relation("ReservedBy")
}

model Contact {
  id               String           @id @default(cuid())
  userId           String
  linkedUserId     String?          // Falls der Kontakt auch ein App-Nutzer ist
  name             String
  birthday         DateTime?
  photoUrl         String?
  category         ContactCategory
  relationshipType RelationshipType?
  state            String?          // Bundesland für länderspezifische Feiertage
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user        User    @relation("ContactOwner", fields: [userId], references: [id], onDelete: Cascade)
  linkedUser  User?   @relation("LinkedContact", fields: [linkedUserId], references: [id])
  events      Event[]

  @@index([userId])
}

enum ContactCategory {
  FAMILY
  FRIENDS
  COLLEAGUES
  OTHER
}

enum RelationshipType {
  MOTHER
  FATHER
  STEPMOTHER
  STEPFATHER
  PARTNER
  SPOUSE
  SIBLING
  GRANDPARENT
  CHILD
  FRIEND
  COLLEAGUE
  OTHER
}

model Event {
  id          String    @id @default(cuid())
  contactId   String
  title       String
  date        DateTime
  isRecurring Boolean   @default(true)
  eventType   EventType
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([date])
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  HOLIDAY
  RELATIONSHIP_HOLIDAY
  CUSTOM
}

model WishList {
  id         String   @id @default(cuid())
  userId     String   @unique
  title      String   @default("Meine Wunschliste")
  isPublic   Boolean  @default(false)
  shareToken String?  @unique @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items WishItem[]
}

model WishItem {
  id          String         @id @default(cuid())
  wishListId  String
  title       String
  description String?
  url         String?
  priceMin    Float?
  priceMax    Float?
  imageUrl    String?
  status      WishItemStatus @default(OPEN)
  reservedById String?       // versteckt vor dem Wunschlistenbesitzer
  priority    Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  wishList   WishList @relation(fields: [wishListId], references: [id], onDelete: Cascade)
  reservedBy User?    @relation("ReservedBy", fields: [reservedById], references: [id])

  @@index([wishListId])
}

enum WishItemStatus {
  OPEN
  RESERVED
  FULFILLED
}

model Invitation {
  id          String    @id @default(cuid())
  invitedById String
  email       String
  name        String?
  token       String    @unique @default(cuid())
  acceptedById String?  @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  invitedByUser User  @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedUser  User? @relation("InvitedUser", fields: [acceptedById], references: [id])

  @@index([token])
  @@index([email])
}

model ReminderSetting {
  id          String     @id @default(cuid())
  userId      String
  eventType   EventType?
  daysBefore  Int
  enabled     Boolean    @default(true)
  createdAt   DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType, daysBefore])
  @@index([userId])
}
